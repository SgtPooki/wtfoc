{
	"name": "wtfoc-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.16.1",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "pnpm -r build",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"clean": "pnpm -r exec rm -rf dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"pnpm": {
		"overrides": {
			"undici@>=6.0.0 <6.24.0": ">=6.24.0",
			"file-type@>=20.0.0 <=21.3.1": ">=21.3.2"
		}
	},
	"dependencies": {
		"@filoz/synapse-core": "^0.3.1",
		"@filoz/synapse-sdk": "^0.40.0",
		"filecoin-pin": "^0.19.0",
		"pino": "^10.3.1",
		"viem": "^2.47.6"
	}
}
