{
	"name": "wtfoc-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.16.1",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "pnpm -r build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "pnpm build && pnpm --filter @wtfoc/web build:server && vitest run --config tests/e2e/vitest.config.ts",
		"test:e2e:ui": "pnpm build && pnpm --filter @wtfoc/web build:server && pnpm --filter @wtfoc/e2e test:ui",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"clean": "pnpm -r exec rm -rf dist",
		"dogfood": "tsx --tsconfig scripts/tsconfig.json scripts/dogfood.ts",
		"dogfood:setup": "tsx --tsconfig scripts/tsconfig.json scripts/dogfood-setup.ts",
		"dogfood:flagship": "bash scripts/dogfood-flagship.sh",
		"autoresearch:sweep": "tsx --tsconfig scripts/tsconfig.json scripts/autoresearch/sweep.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"pnpm": {
		"overrides": {
			"undici@>=6.0.0 <6.24.0": ">=6.24.0",
			"file-type@>=20.0.0 <=21.3.1": ">=21.3.2"
		},
		"onlyBuiltDependencies": [
			"@ipshipyard/node-datachannel",
			"node-datachannel",
			"onnxruntime-node"
		]
	}
}
