{
	"name": "@wtfoc/cli",
	"version": "0.0.3",
	"description": "CLI for the wtfoc cross-source knowledge graph",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SgtPooki/wtfoc.git",
		"directory": "packages/cli"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=24"
	},
	"bin": {
		"wtfoc": "./dist/cli.js"
	},
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli.js"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b && cp src/ui.html dist/ui.html",
		"test": "vitest run"
	},
	"dependencies": {
		"@wtfoc/common": "workspace:*",
		"@wtfoc/config": "workspace:*",
		"@wtfoc/ingest": "workspace:*",
		"@wtfoc/search": "workspace:*",
		"@wtfoc/store": "workspace:*",
		"commander": "^14.0.0"
	},
	"devDependencies": {
		"typescript": "^5.8.0"
	}
}
