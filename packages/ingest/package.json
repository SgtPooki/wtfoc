{
	"name": "@wtfoc/ingest",
	"version": "0.0.2",
	"description": "Source adapters for ingesting code, GitHub, Slack, Discord, and websites into wtfoc",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SgtPooki/wtfoc.git",
