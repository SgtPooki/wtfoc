{
	"name": "@wtfoc/mcp-server",
	"version": "0.0.4",
	"description": "Model Context Protocol server exposing wtfoc tools for Claude",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SgtPooki/wtfoc.git",
		"directory": "packages/mcp-server"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=24"
	},
	"bin": {
		"wtfoc-mcp": "./dist/index.js"
	},
	"exports": {
		".": "./dist/index.js",
		"./server": "./dist/server.js"
	},
	"typesVersions": {
		"*": {
			"server": [
				"./dist/server.d.ts"
			]
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b",
		"test": "vitest run"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"@wtfoc/common": "workspace:*",
		"@wtfoc/config": "workspace:*",
		"@wtfoc/ingest": "workspace:*",
		"@wtfoc/search": "workspace:*",
		"@wtfoc/store": "workspace:*",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"typescript": "^5.8.0"
	}
}
