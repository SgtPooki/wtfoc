# wtfoc environment variables
# Copy to .env and fill in values

# Storage backend: "local" or "foc" (default: local)
WTFOC_STORAGE=local

# FOC network: "calibration" or "mainnet" (default: calibration)
WTFOC_NETWORK=calibration

# FOC wallet private key (required for FOC storage only)
# WTFOC_PRIVATE_KEY=0x...

# OpenAI API key (only if using OpenAI embedder)
# WTFOC_OPENAI_API_KEY=sk-...

# GitHub token (for GitHub source adapter)
# WTFOC_GITHUB_TOKEN=ghp_...
